# zapytaj o liczbe i sprawdz, czy jest liczba pierwsza (dzielniki od 2 do tej liczby)
test_liczba = 13
lista_reszt = []

for g in range(2,test_liczba):
    while g*g <= test_liczba:
        reszta = test_liczba%g
        lista_reszt.append(reszta)
        if reszta == 0:
            print("Ta liczba nie jest pierwsza.")
            break
if 0 not in lista_reszt:
    print("Ta liczba jest pierwsza.")

