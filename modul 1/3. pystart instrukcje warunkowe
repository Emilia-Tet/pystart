# odbierz liczbe i powiedz, czy jest parzysta
# odbierz 2 wartosci, porownaj je i powiedz uzytkownikowi
# zapytaj o temperature, -10 "zostan w domu", -10 do 20 "wez kurtke", wyzej "baw sie dobrze"

temp = float(input("Jaka jest dzisiaj temperatura?"))

if temp <= -10:
    print("zostan w domu")
elif -10< temp <= 20:
    print("wez kurtke")
else:
    print("Baw sie dobrze")


