# uwaga, bo samochod spala 6l/100 km, a przejechal 150 km
def cena_za_trase(dlugosc_trasy, cena_za_litr, spalanie):
    cena_koncowa = dlugosc_trasy*spalanie*cena_za_litr/100
    info = print(f"Cena za te trase wynosi {cena_koncowa} zl. ")
    return(info)
spalanie = 6
litr = 6
dlugosc = 150
cena_za_trase(dlugosc, litr, spalanie)

