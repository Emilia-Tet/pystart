# cw 3

try:
    liczba = int(input("Podaj liczbe calkowita:"))
    if liczba%5 == 0 and liczba%11 ==0:
        print(f"{liczba} jest podzielne przez 5 i przez 11.")
    elif liczba%5==0 and liczba%11 !=0:
        print(f"{liczba} jest podzielne przez 5 i nie jest podzielne przez 11.")
    elif liczba%5!=0 and liczba%11 ==0:
        print(f"{liczba} jest podzielne przez 11 i nie jest podzielne przez 5.")
    else:
        print(f"{liczba} nie jest podzielna ani przez 5, ani przez 11.")

except ValueError:
    print(f"To nie jest liczba calkowita.")
