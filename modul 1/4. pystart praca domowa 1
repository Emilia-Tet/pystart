import math
wierzcholek_Ax = int(input("Podaj wspolrzedna x wierzcholka A: "))
wierzcholek_Bx = int(input("Podaj wspolrzedna x wierzcholka B: "))
wierzcholek_Cx = int(input("Podaj wspolrzedna x wierzcholka C: "))

wierzcholek_Ay = int(input("Podaj wspolrzedna y wierzcholka A: "))
wierzcholek_By = int(input("Podaj wspolrzedna y wierzcholka B: "))
wierzcholek_Cy = int(input("Podaj wspolrzedna y wierzcholka C: "))

pole = abs((wierzcholek_Bx - wierzcholek_Ax)*(wierzcholek_Cy - wierzcholek_Ay)- (wierzcholek_By - wierzcholek_Ay)*(wierzcholek_Cx - wierzcholek_Ax))/2
